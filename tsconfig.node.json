{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node", "electron"],
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "outDir": "out-tsc/node"
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "tests/unit/**/*.ts",
    "tests/e2e/**/*.ts"
  ]
}
