{
  "name": "appdeck-sync",
  "version": "0.1.0",
  "private": true,
  "description": "AppDeck E2EE sync backend (Cloudflare Worker + D1).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create appdeck",
    "db:migrate": "wrangler d1 migrations apply appdeck --remote",
    "db:migrate:local": "wrangler d1 migrations apply appdeck --local",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "typescript": "^5.9.3",
    "wrangler": "^4"
  }
}
