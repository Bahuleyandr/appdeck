{
  "name": "appdeck",
  "version": "0.1.0",
  "description": "A personal-first desktop workspace app for isolated, sleepable web services.",
  "main": "out/main/index.js",
  "author": "AppDeck",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run rebuild:electron && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run rebuild:node && vitest run",
    "test:e2e": "npm run rebuild:electron && npm run build && playwright test",
    "dist": "npm run build && electron-builder --publish never",
    "dist:portable": "npm run build && electron-builder --win portable --publish never",
    "release": "npm run build && electron-builder --publish always",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "better-sqlite3": "12.11.1",
    "bip39": "3.1.0",
    "chokidar": "5.0.0",
    "electron-updater": "^6.8.9",
    "libsodium-wrappers-sumo": "0.8.4",
    "lucide-react": "1.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.0.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.5.0",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.0.1",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "3.4.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "7.3.5",
    "vitest": "4.1.9"
  }
}
